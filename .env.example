# PostgreSQL (required). Free tier: https://neon.tech or https://vercel.com/storage/postgres
# Use sslmode=require for hosted providers.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
# REQUIRED in production (Vercel: Project → Settings → Environment Variables).
# If missing, sign-in shows: "Server error" / "problem with the server configuration".
AUTH_SECRET="replace-with-a-long-random-string"
# Legacy name; Auth.js also accepts this if AUTH_SECRET is unset:
# NEXTAUTH_SECRET="same-as-above"

# Production URL (optional on Vercel; set if callbacks/redirects misbehave)
# AUTH_URL="https://your-app.vercel.app"
# Self-hosted production without VERCEL=1 may need: AUTH_TRUST_HOST=true

# Optional: Google sign-in — https://console.cloud.google.com/apis/credentials
# Create OAuth client (Web). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_DOMAIN/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
